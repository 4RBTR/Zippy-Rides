// Zippy Rides - Vehicle Maintenance Tracker
// Prisma Schema for Supabase PostgreSQL

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── User ────────────────────────────────────────────────────────────
// Mirrors Supabase auth.users — same UUID is used as the primary key.
model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String?
  avatarUrl String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  vehicles  Vehicle[]
}

// ─── Vehicle ─────────────────────────────────────────────────────────
enum VehicleType {
  MOTOR
  MOBIL
}

model Vehicle {
  id              String           @id @default(uuid())
  userId          String
  name            String
  type            VehicleType
  currentMileage  Int              @default(0)
  imageUrl        String?
  annualTaxDate   DateTime?
  fiveYearTaxDate DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  partIntervals   PartInterval[]
  journals        VehicleJournal[]

  @@index([userId])
}

// ─── Part Interval ───────────────────────────────────────────────────
// Rule definition: e.g. "Air Filter every 10,000 km"
model PartInterval {
  id           String            @id @default(uuid())
  vehicleId    String
  partName     String
  intervalKm   Int
  createdAt    DateTime          @default(now())
  vehicle      Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  replacements PartReplacement[]

  @@index([vehicleId])
}

// ─── Part Replacement ────────────────────────────────────────────────
// Actual service log entry
model PartReplacement {
  id              String       @id @default(uuid())
  partIntervalId  String
  replacedAtKm    Int
  cost            Float        @default(0)
  receiptImageUrl String?
  replacedAt      DateTime     @default(now())
  partInterval    PartInterval @relation(fields: [partIntervalId], references: [id], onDelete: Cascade)

  @@index([partIntervalId])
}

// ─── Vehicle Journal ─────────────────────────────────────────────────
enum JournalType {
  SYMPTOM
  MODIFICATION
  GENERAL
}

model VehicleJournal {
  id          String      @id @default(uuid())
  vehicleId   String
  type        JournalType
  title       String
  description String?
  createdAt   DateTime    @default(now())
  vehicle     Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}
